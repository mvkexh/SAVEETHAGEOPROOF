# ===================================================
# Saveetha GeoTag - E2E Test Environment Config
# ===================================================

# --- Appium Server ---
APPIUM_HOST=localhost
APPIUM_PORT=4723

# --- Android App Config ---
ANDROID_PLATFORM_VERSION=16
ANDROID_DEVICE_NAME=c91981ca
APP_PACKAGE=com.example.saveethageotag
APP_ACTIVITY=.MainActivity
# Path to your compiled APK (update this after building)
APP_PATH=../app/build/outputs/apk/debug/app-debug.apk

# --- Selenium / Web Config ---
WEB_BASE_URL=http://localhost:3000
BROWSER=chrome
HEADLESS=false

# --- Report Config ---
REPORT_OUTPUT_DIR=./reports/output
REPORT_FILENAME=SaveethaGeoTag_E2E_TestReport

# --- Timeouts (ms) ---
IMPLICIT_WAIT=10000
EXPLICIT_WAIT=30000
ELEMENT_TIMEOUT=15000
