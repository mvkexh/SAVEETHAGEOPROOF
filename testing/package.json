{
  "name": "saveethageotag-e2e-tests",
  "version": "2.0.0",
  "description": "Complete End-to-End Testing Suite — Saveetha GeoTag App (Appium Mobile + Selenium Web + Excel + HTML + Allure Reports)",
  "main": "index.js",
  "scripts": {
    "test:appium":        "mocha appium-tests/**/*.test.js --timeout 120000 --reporter spec --exit",
    "test:selenium":      "mocha selenium-tests/**/*.test.js --timeout 60000 --reporter spec --exit",
    "test:all":           "mocha \"appium-tests/**/*.test.js\" \"selenium-tests/**/*.test.js\" --timeout 120000 --reporter spec --exit",
    "test:allure":        "mocha \"appium-tests/**/*.test.js\" \"selenium-tests/**/*.test.js\" --timeout 120000 --reporter allure-mocha --reporter-options resultsDir=reports/allure-results --exit",
    "test:html":          "mocha \"appium-tests/**/*.test.js\" \"selenium-tests/**/*.test.js\" --timeout 120000 --reporter mochawesome --reporter-options reportDir=reports/html,reportFilename=TestReport,overwrite=true --exit",
    "test:ci":            "mocha \"appium-tests/**/*.test.js\" \"selenium-tests/**/*.test.js\" --timeout 120000 --reporter mocha-junit-reporter --reporter-options mochaFile=reports/output/junit-results.xml --exit",
    "test:report":        "node reports/generateExcelReport.js",
    "test:html-report":   "node reports/generateHtmlReport.js",
    "test:allure-open":   "allure generate reports/allure-results --clean -o reports/allure-report && allure open reports/allure-report",
    "test:gha-selenium":  "node scripts/generate_gha_reports.js selenium",
    "test:gha-master":    "node scripts/generate_gha_reports.js master",
    "test:run-all":       "node scripts/runAll.js",
    "test:appium-suite":  "mocha appium-tests/[0-9]*.test.js --timeout 120000 --reporter spec --exit",
    "clear:results":      "node -e \"require('./utils/testResults').clearResults()\"",
    "start":              "node index.js",
    "test:load":          "mocha load-tests/16_loadTesting.test.js --timeout 300000 --reporter spec --exit",
    "test:load-report":   "mocha load-tests/16_loadTesting.test.js --timeout 300000 --reporter mochawesome --reporter-options reportDir=load-tests/reports,reportFilename=LoadTestReport,overwrite=true --exit",
    "test:k6":            "node load-tests/runK6.js"
  },
  "dependencies": {
    "@wdio/appium-service": "^8.27.0",
    "allure-mocha":          "^2.15.1",
    "allure-js-commons":     "^2.15.1",
    "axios":                 "^1.6.7",
    "chai":                  "^4.5.0",
    "chromedriver":          "^121.0.0",
    "dotenv":                "^16.6.1",
    "exceljs":               "^4.4.0",
    "fs-extra":              "^11.3.5",
    "mocha":                 "^10.8.2",
    "mocha-junit-reporter":  "^2.2.1",
    "moment":                "^2.30.1",
    "selenium-webdriver":    "^4.16.0",
    "webdriverio":           "^8.27.0",
    "winston":               "^3.19.0"
  },
  "devDependencies": {
    "mochawesome":                   "^7.1.3",
    "mochawesome-merge":             "^4.3.0",
    "mochawesome-report-generator":  "^6.2.0",
    "allure-commandline":            "^2.15.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "selenium", "appium", "e2e", "testing", "android",
    "geotag", "saveetha", "allure", "excel", "mocha"
  ],
  "author": "Saveetha Testing Team",
  "license": "MIT"
}
